default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    key_path = File.expand_path(ENV["ASC_KEY_PATH"])

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: key_path,
    )

    latest_build = latest_testflight_build_number(api_key: api_key)
    increment_build_number(build_number: latest_build + 1)

    get_certificates(
      api_key: api_key,
      platform: "ios",
    )

    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.travelbudget.travelBudget",
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: "53GU4PUP6R",
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: ["Runner"],
    )

    Bundler.with_unbundled_env do
      sh("cd ../.. && /opt/homebrew/bin/flutter build ios --release --no-codesign")
    end

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      archive_path: "../build/ios/archive/Runner.xcarchive",
      output_directory: "../build/ios/ipa",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        teamID: "53GU4PUP6R",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.travelbudget.travelBudget" => profile_name,
        },
      },
      xcargs: "-authenticationKeyPath '#{key_path}' -authenticationKeyID '#{ENV["ASC_KEY_ID"]}' -authenticationKeyIssuerID '#{ENV["ASC_ISSUER_ID"]}'",
      xcodebuild_formatter: "",
    )

    update_code_signing_settings(
      use_automatic_signing: true,
      path: "Runner.xcodeproj",
      team_id: "53GU4PUP6R",
      targets: ["Runner"],
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
